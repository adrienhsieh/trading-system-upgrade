# ── Telegram Bot 設定 ─────────────────────────────────────────
# 步驟：
#  1. Telegram 搜尋 @BotFather → /newbot → 取得 Token
#  2. 複製此檔案為 .env 並填入 Token
#  3. 啟動程式後輸入 /我的id 取得 Chat ID
#  4. 把 Chat ID 填入 TELEGRAM_ALLOWED_IDS 後重啟

TELEGRAM_BOT_TOKEN=your_bot_token_here

# 安全白名單，只有填入的 ID 才能使用 Bot
# 先留空啟動，取得 ID 後再填入，多個用逗號分隔
TELEGRAM_ALLOWED_IDS=your_chat_id_here

# ── AI 情報分析（選填） ───────────────────────────────────────
# Groq API Key（免費申請：https://console.groq.com）
# 用於 AI 新聞情緒分析與每日市場情報摘要
GROQ_API_KEY=your_groq_api_key_here

# ── 伺服器設定（選填） ────────────────────────────────────────
# PORT=8787

# ── 多人登入（JWT）設定 ───────────────────────────────────────
# 正式環境務必換成一組長隨機字串（例如 python -c "import secrets;print(secrets.token_hex(32))"）
JWT_SECRET_KEY=please_change_me_to_a_long_random_string
# Token 有效時數
JWT_EXPIRY_HOURS=24

# ── 即時監控（盤中 09:00-13:30 自動抓取）設定 ───────────────────
# FinMind Token（選填，未填也可運作，但有較嚴格的呼叫頻率限制）
# 申請：https://finmindtrade.com/
FINMIND_TOKEN=
# 預設抓取頻率（秒），可於「即時監控」頁面即時調整並立即套用，無需重啟
INTRADAY_FETCH_INTERVAL=5
