# ── Telegram Bot 設定 ─────────────────────────────────────────
# 步驟：
#  1. Telegram 搜尋 @BotFather → /newbot → 取得 Token
#  2. 複製此檔案為 .env 並填入 Token
#  3. 啟動程式後輸入 /我的id 取得 Chat ID
#  4. 把 Chat ID 填入 TELEGRAM_ALLOWED_IDS 後重啟

TELEGRAM_BOT_TOKEN=your_bot_token_here

# 安全白名單，只有填入的 ID 才能使用 Bot
# 先留空啟動，取得 ID 後再填入，多個用逗號分隔
TELEGRAM_ALLOWED_IDS=your_chat_id_here

# ── AI 情報分析（選填） ───────────────────────────────────────
# Groq API Key（免費申請：https://console.groq.com）
# 用於 AI 新聞情緒分析與每日市場情報摘要
GROQ_API_KEY=your_groq_api_key_here

# ── 伺服器設定（選填） ────────────────────────────────────────
# PORT=8787
